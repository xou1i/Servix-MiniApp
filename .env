# ── API Configuration ─────────────────────────────────────────────────────
# For local dev (routes through Vite proxy → bypasses CORS):
VITE_API_BASE_URL=https://itchy-pugs-try.loca.lt/api/v1

# The actual backend origin (used by Vite proxy target):
VITE_BACKEND_ORIGIN=https://itchy-pugs-try.loca.lt

# ── For PRODUCTION deployment, change VITE_API_BASE_URL to the full URL:
VITE_API_BASE_URL=https://itchy-pugs-try.loca.lt/api/v1

# ── Dev Mode: set to "true" to skip real API login (works offline) ────────
# Set to "false" or remove when backend is available
VITE_USE_MOCK_AUTH=false

# ── (Optional) Dev test token — paste a JWT here for Swagger testing ──────
# VITE_DEV_TEST_TOKEN=
